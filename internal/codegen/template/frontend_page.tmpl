<!-- {{ .HeaderComment }} -->
<!-- xkit version: {{ .Generated.Version }} -->
<!-- generated at: {{ .Generated.GeneratedAt }} -->
<script lang="ts" setup>
import type { VbenFormProps } from '@vben/common-ui';
{{- if .TreeEnabled }}
import type { TreeSelectProps } from 'ant-design-vue';
{{- end }}

import type { {{ .EntityType }} } from '{{ .ProviderImportPath }}';
import type { VxeTableGridOptions } from '#/adapter/vxe-table';

import { computed, nextTick, {{- if .RelationRuntimes }} onMounted,{{- end }} reactive, ref{{- if .RelationRuntimes }}, unref{{- end }} } from 'vue';

import { Page } from '@vben/common-ui';
import { IconifyIcon } from '@vben/icons';
{{- if .TenantScoped }}
import { useUserStore } from '@vben/stores';
{{- end }}

import { Button, Form, message, Modal, Popconfirm, Space } from 'ant-design-vue';

import { useVbenVxeGrid } from '#/adapter/vxe-table';
import AdminGeneratedForm from '#/components/admin-generated-form/index.vue';
{{- if not .TreeEnabled }}
import { normalizeAdminTableSortDirection } from '#/components/admin-table-toolbar/shared';
{{- end }}
import { $t } from '#/locales';

import {
  buildFormOptions as buildGeneratedDialogFormOptions,
  buildListGridColumns as buildGeneratedListGridColumns,
  buildSearchFormOptions as buildGeneratedSearchFormOptions,
{{- if not .TreeEnabled }}
  defaultSortDirection,
  defaultSortField,
{{- end }}
  i18nPrefix,
} from '{{ .MetaImportPath }}';
import {
{{- range .ProviderFuncs }}
  {{ . }},
{{- end }}
} from '{{ .ProviderImportPath }}';
{{- if .DefineOptionsName }}

defineOptions({ name: '{{ .DefineOptionsName }}' });
{{- end }}

const modalOpen = ref(false);
const submitting = ref(false);
{{- if .RelationRuntimes }}
const optionLoading = ref(false);
{{- end }}
const editingId = ref<number>();
{{- if .TenantScoped }}
const editingReadonly = ref(false);
const userStore = useUserStore();
const currentTenantId = computed(() => userStore.userInfo?.tenantId ?? 0);
{{- end }}
const formRef = ref();
const formModel = reactive<Record<string, any>>({});

const modalTitle = computed(() =>
  editingId.value
{{- if .TenantScoped }}
    ? editingReadonly.value
      ? $t('common.detail')
      : $t(`${i18nPrefix}.editTitle`) || $t('common.edit')
{{- else }}
    ? $t(`${i18nPrefix}.editTitle`) || $t('common.edit')
{{- end }}
    : $t(`${i18nPrefix}.createTitle`) || $t('common.create'),
);

const generatedFormOptions = buildGeneratedSearchFormOptions($t);
const generatedDialogFormOptions = buildGeneratedDialogFormOptions($t);
const formFieldNames = (generatedDialogFormOptions.schema || []).map(
  (item) => item.fieldName,
);
{{- if .TreeEnabled }}
const treeItems = ref<{{ .EntityType }}[]>([]);
{{- end }}
{{- range .RelationRuntimes }}
const {{ .OptionsVarName }} = ref<Array<{ label: string; value: number | string }>>([]);
const {{ .OptionsMapVarName }} = computed(() =>
  new Map({{ .OptionsVarName }}.value.map((item) => [item.value, item.label])),
);
{{- end }}
{{- if .TreeEnabled }}
type TreeOption = NonNullable<TreeSelectProps['treeData']>[number];

const parentTreeOptions = computed<TreeOption[]>(() =>
  buildParentTreeOptions(treeItems.value, editingId.value),
);
{{- end }}
{{- range .EnumRuntimes }}
const {{ .TextMapVarName }} = computed(() => ({
{{- range .EnumItems }}
  {{ .Key }}: $t('{{ .I18nKey }}'),
{{- end }}
}));
{{- end }}

{{- if or .RelationRuntimes .TreeEnabled }}
function resolveComponentProps(item: any) {
  if (typeof item.componentProps === 'function') {
    return item.componentProps({});
  }
  return item.componentProps || {};
}
{{- end }}
{{- if .RelationRuntimes }}
{{- range .RelationRuntimes }}
function {{ .SearchPatchFuncName }}(item: any) {
  return {
    ...item,
    component: 'Select',
    formItemClass: 'md:col-span-1',
    componentProps: () => ({
      ...resolveComponentProps(item),
      allowClear: true,
      loading: optionLoading.value,
      options: unref({{ .OptionsVarName }}),
      placeholder: resolveComponentProps(item).placeholder,
      showSearch: true,
    }),
  };
}

function {{ .DialogPatchFuncName }}(item: any) {
  return {
    ...item,
    component: 'Select',
    componentProps: {
      ...resolveComponentProps(item),
      allowClear: true,
      loading: optionLoading.value,
      options: {{ .OptionsVarName }}.value,
      placeholder: $t(`${i18nPrefix}.{{ .PlaceholderKey }}`),
      showSearch: true,
    },
  };
}
{{- end }}
{{- end }}

const formOptions: VbenFormProps = {
  ...generatedFormOptions,
  schema: (generatedFormOptions.schema || []).map((item): any => {
{{- if .RelationRuntimes }}
    switch (item.fieldName) {
{{- range .RelationRuntimes }}
      case '{{ .FieldName }}': {
        return {{ .SearchPatchFuncName }}(item);
      }
{{- end }}
      default: {
        return {
          ...item,
          formItemClass: 'md:col-span-1',
        };
      }
    }
{{- else }}
    return {
      ...item,
      formItemClass: 'md:col-span-1',
    };
{{- end }}
  }),
  wrapperClass: 'grid-cols-1 md:grid-cols-3 xl:grid-cols-4',
};

const dialogFormSchema = computed(() =>
  (generatedDialogFormOptions.schema || []).map((item): any => {
{{- if .TreeEnabled }}
    if (item.fieldName === '{{ .TreeParentField }}') {
      return {
        ...item,
        component: 'TreeSelect',
        componentProps: {
          ...resolveComponentProps(item),
          allowClear: true,
          placeholder: $t(`${i18nPrefix}.select{{- if eq .TreeParentField "parentId" -}}ParentId{{- else -}}{{ upperFirst .TreeParentField }}{{- end -}}`) || resolveComponentProps(item).placeholder,
          showSearch: true,
          treeData: parentTreeOptions.value,
          treeDefaultExpandAll: true,
          treeNodeFilterProp: 'label',
        },
      };
    }
{{- end }}
{{- if .RelationRuntimes }}
    switch (item.fieldName) {
{{- range .RelationRuntimes }}
      case '{{ .FieldName }}': {
        return {{ .DialogPatchFuncName }}(item);
      }
{{- end }}
      default: {
        return {
          ...item,
        };
      }
    }
{{- else }}
    return {
      ...item,
    };
{{- end }}
  }),
);

const generatedColumns = buildGeneratedListGridColumns($t) ?? [];
{{- if .TreeEnabled }}
const gridColumns = generatedColumns.map((column: any, index: number) => {
  if (index === 0 || column?.field === '{{ .TreeTitleField }}') {
    return {
      ...column,
      treeNode: true,
{{- if .TreeIconEnabled }}
      slots: {
        ...(column?.slots || {}),
        default: 'treeTitle',
      },
{{- end }}
    };
  }
  return column;
});
{{- else }}
const gridColumns = generatedColumns;
{{- end }}

const gridOptions: VxeTableGridOptions<{{ .EntityType }}> = {
  border: false,
  columnConfig: {
    resizable: true,
  },
  columns: [
    ...gridColumns,
    {
      field: 'action',
      fixed: 'right',
      slots: { default: 'action' },
      title: $t('ui.table.action'),
      width: 150,
    },
  ],
{{- if .ExportEnabled }}
  exportConfig: {
    filename: '{{ .ExportFilename }}',
    type: 'csv',
  },
{{- end }}
  height: 'auto',
  keepSource: true,
{{- if .TreeEnabled }}
  pagerConfig: {
    enabled: false,
  },
{{- else }}
  pagerConfig: {},
{{- end }}
  proxyConfig: {
    ajax: {
      query: async (
{{- if .TreeEnabled }}
        {}: { page: any; sort: any },
{{- else }}
        { page, sort }: { page: any; sort: any },
{{- end }}
        formValues: Record<string, any>,
      ) => {
{{- if .TreeEnabled }}
        const result = await {{ .ListFuncName }}({
          ...formValues,
          page: 1,
          pageSize: 200,
        });
        treeItems.value = result.items;
        return result;
{{- else }}
        const sortField = String(sort.field || defaultSortField);
        const direction =
          normalizeAdminTableSortDirection(sort.order) ?? defaultSortDirection;
        return await {{ .ListFuncName }}({
          ...formValues,
          page: page.currentPage,
          pageSize: page.pageSize,
          sorting: [{ direction, field: toBackendSortField(sortField) }],
        });
{{- end }}
      },
    },
{{- if .TreeEnabled }}
    sort: false,
{{- else }}
    sort: true,
{{- end }}
  },
  rowConfig: {
    isHover: true,
  },
  stripe: true,
  toolbarConfig: {
    custom: true,
{{- if .ExportEnabled }}
    export: true,
{{- end }}
    refresh: true,
    slots: {
      toolPrefix: 'toolPrefix',
    },
    zoom: true,
  },
{{- if .TreeEnabled }}
  treeConfig: {
    line: true,
    rowField: 'id',
    transform: false,
  },
{{- end }}
};

function resetFormModel() {
  for (const key of formFieldNames) {
    formModel[key] = undefined;
  }
}
{{- if .TreeEnabled }}

function buildParentTreeOptions(
  items: {{ .EntityType }}[],
  excludeId?: number,
): TreeOption[] {
  return items.flatMap((item) => {
    if (item.id === undefined) {
      return [];
    }
    if (excludeId !== undefined && item.id === excludeId) {
      return [];
    }
    const children = buildParentTreeOptions(
      (item.{{ .TreeChildrenField }} ?? []) as {{ .EntityType }}[],
      excludeId,
    );
    return [
      {
        children: children.length > 0 ? children : undefined,
        key: item.id,
        label: (item as Record<string, any>).name ?? (item as Record<string, any>).groupName ?? `#${item.id}`,
        value: item.id,
      },
    ];
  });
}
{{- else }}
function toBackendSortField(sortField: string) {
  return sortField.replaceAll(/[A-Z]/g, (match) => `_${match.toLowerCase()}`);
}
{{- end }}
{{- if .TenantScoped }}

function canMutateRecord(record: {{ .EntityType }}) {
  return (record.tenantId ?? 0) === currentTenantId.value;
}
{{- end }}

async function openCreateModal() {
  editingId.value = undefined;
{{- if .TenantScoped }}
  editingReadonly.value = false;
{{- end }}
  resetFormModel();
  modalOpen.value = true;
  await nextTick();
  formRef.value?.clearValidate();
}

async function openEditModal(record: {{ .EntityType }}) {
  if (!record.id) {
    return;
  }
  editingId.value = record.id;
{{- if .TenantScoped }}
  editingReadonly.value = !canMutateRecord(record);
{{- end }}
  const data = await {{ .GetFuncName }}(record.id);
  resetFormModel();
  Object.assign(formModel, data || {});
  modalOpen.value = true;
  await nextTick();
  formRef.value?.clearValidate();
}

async function handleSubmit() {
{{- if .TenantScoped }}
  if (editingReadonly.value) {
    modalOpen.value = false;
    return;
  }
{{- end }}
  await formRef.value?.validate();
  submitting.value = true;
  try {
    if (editingId.value) {
      await {{ .UpdateFuncName }}(editingId.value, formModel);
      message.success($t(`${i18nPrefix}.updateSuccess`) || $t('common.edit'));
    } else {
      await {{ .CreateFuncName }}(formModel);
      message.success($t(`${i18nPrefix}.createSuccess`) || $t('common.create'));
    }
    modalOpen.value = false;
    await gridApi.reload();
  } finally {
    submitting.value = false;
  }
}

async function handleDelete(record: {{ .EntityType }}) {
  if (!record.id) {
    return;
  }
  await {{ .DeleteFuncName }}(record.id);
  message.success($t(`${i18nPrefix}.deleteSuccess`) || $t('common.delete'));
  await gridApi.reload();
}
{{- range .RelationRuntimes }}

function {{ .ResolveFuncName }}(value: number | string | undefined) {
  if (value === null || value === undefined) {
    return '';
  }
  return {{ .OptionsMapVarName }}.value.get(value) ?? value;
}
{{- end }}
{{- range .EnumRuntimes }}

function {{ .ResolveFuncName }}(value: string | undefined) {
  if (!value) {
    return '';
  }
  return {{ .TextMapVarName }}.value[value as keyof typeof {{ .TextMapVarName }}.value] ?? value;
}
{{- end }}
{{- if .RelationRuntimes }}

async function loadRelationOptions() {
  optionLoading.value = true;
  try {
{{- range .RelationRuntimes }}
    {{ .OptionsVarName }}.value = await {{ .FuncName }}();
{{- end }}
  } finally {
    optionLoading.value = false;
  }
}
{{- end }}

const [Grid, gridApi] = useVbenVxeGrid<{{ .EntityType }}>({
  gridClass: '{{ .GridClassName }}',
  gridOptions,
  formOptions,
});
{{- if .RelationRuntimes }}

onMounted(() => {
  void loadRelationOptions();
});
{{- end }}
</script>

<template>
  <Page auto-content-height :title="$t('{{ .PageTitleKey }}')">
    <Grid :table-title="$t('{{ .PageTitleKey }}')">
      <template #toolPrefix>
        <Button type="primary" @click="openCreateModal">
          <template #icon>
            <IconifyIcon icon="lucide:plus" />
          </template>
          {{ "{{" }} $t('common.create') {{ "}}" }}
        </Button>
      </template>
{{- if .TreeIconEnabled }}

      <template #treeTitle="{ row }">
        <div class="flex items-center gap-2">
          <IconifyIcon
            v-if="row.{{ .TreeIconField }}"
            :icon="row.{{ .TreeIconField }}"
            class="text-[16px] text-muted-foreground"
          />
          <span>{{ "{{" }} row.{{ .TreeTitleField }} {{ "}}" }}</span>
        </div>
      </template>
{{- end }}

      <template #action="{ row }">
        <Space>
          <Button size="small" type="link" @click="openEditModal(row)">
            {{ "{{" }} {{- if .TenantScoped }} canMutateRecord(row) ? $t('common.edit') : $t('common.detail') {{- else }} $t('common.edit') {{- end }} {{ "}}" }}
          </Button>
          <Popconfirm
            :title="$t('ui.actionMessage.deleteConfirm', [$t('{{ .PageModuleNameKey }}')])"
            @confirm="handleDelete(row)"
          >
            <Button danger size="small" type="link"{{- if .TenantScoped }} :disabled="!canMutateRecord(row)"{{- end }}>
              {{ "{{" }} $t('common.delete') {{ "}}" }}
            </Button>
          </Popconfirm>
        </Space>
      </template>
{{- range .RelationRuntimes }}

      <template #{{ .FieldName }}="{ row }">
        {{ "{{" }} {{ .ResolveFuncName }}(row.{{ .FieldName }}) {{ "}}" }}
      </template>
{{- end }}
{{- range .EnumRuntimes }}

      <template #{{ .FieldName }}="{ row }">
        {{ "{{" }} {{ .ResolveFuncName }}(row.{{ .FieldName }}) {{ "}}" }}
      </template>
{{- end }}
    </Grid>

    <Modal
      v-model:open="modalOpen"
      :confirm-loading="submitting"
      {{- if .TenantScoped }}
      :ok-button-props="{ disabled: editingReadonly }"
      {{- end }}
      :title="modalTitle"
      destroy-on-close
      width="720px"
      @ok="handleSubmit"
    >
      <Form ref="formRef" :model="formModel" :label-col="{ span: 5 }">
        <AdminGeneratedForm :model="formModel" :schema="dialogFormSchema" />
      </Form>
    </Modal>
  </Page>
</template>
